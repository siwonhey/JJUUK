{
  "name": "jjuuk",
  "version": "0.1.0",
  "description": "JJUUK — Interactive Posture Companion. Webcam-driven turtle/giraffe overlay that nudges you back to good posture.",
  "main": "main/main.js",
  "scripts": {
    "start": "electron .",
    "postinstall": "node scripts/fetch-model.js",
    "fetch-model": "node scripts/fetch-model.js",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac"
  },
  "author": "siwon",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.18",
    "electron-store": "^8.2.0",
    "gsap": "^3.12.5",
    "pretendard": "^1.3.9"
  },
  "build": {
    "appId": "com.siwon.jjuuk",
    "productName": "JJUUK",
    "files": [
      "main/**/*",
      "renderer/**/*",
      "assets/**/*",
      "shared/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.healthcare-fitness",
      "icon": "assets/app-icon.png",
      "extendInfo": {
        "NSCameraUsageDescription": "JJUUK 은 자세 변화를 감지하기 위해 카메라 영상을 사용합니다. 영상은 로컬에서만 처리되며 외부로 전송되지 않습니다."
      }
    },
    "win": {
      "target": "nsis",
      "icon": "assets/app-icon.png"
    }
  }
}
